generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "auth_service", "error_logs"]
}

model Master {
  id        Int       @id @default(autoincrement())
  role      String    @db.VarChar(50)
  name      String
  login     String?   @unique
  password  String?
  passport  String?
  contract  String?
  status    String    @db.VarChar(50)
  note      String?
  chatId    String?   @map("chat_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  orders Order[]

  @@index([status])
  @@index([name])
  @@index([chatId])
  @@schema("auth_service")
  @@map("masters")
}

model Director {
  id            Int       @id @default(autoincrement())
  role          String    @db.VarChar(50)
  name          String
  login         String    @unique
  password      String
  status        String    @db.VarChar(50)
  contract      String?
  passport      String?
  note          String?
  tgId          String?   @map("tg_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  orders        Order[]
  cashApprovals Cash[]    @relation("CashApprover")

  @@index([status])
  @@index([name])
  @@schema("auth_service")
  @@map("directors")
}

model CallcentreAdmin {
  id        Int       @id @default(autoincrement())
  role      String    @db.VarChar(50)
  name      String
  login     String    @unique
  password  String
  status    String    @db.VarChar(50)
  note      String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  orders Order[] @relation("CallcentreAdminOrders")

  @@index([status])
  @@schema("auth_service")
  @@map("admins")
}

model CallcentreOperator {
  id         Int       @id @default(autoincrement())
  role       String    @db.VarChar(50)
  name       String
  login      String    @unique
  password   String
  status     String
  passport   String?
  contract   String?
  note       String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  sipAddress String?   @map("sip_address")

  orders Order[] @relation("CallcentreOperatorOrders")

  @@index([status])
  @@index([name])
  @@schema("auth_service")
  @@map("operators")
}

model UserCity {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  userType  String   @map("user_type") @db.VarChar(20)
  cityId    Int      @map("city_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, userType, cityId])
  @@index([userId, userType])
  @@index([cityId])
  @@schema("auth_service")
  @@map("user_cities")
}

model Order {
  id                   Int                 @id @default(autoincrement())
  rk                   String
  city                 String
  avitoName            String?
  phone                String
  typeOrder            String
  clientName           String
  address              String
  dateMeeting          DateTime
  typeEquipment        String
  problem              String
  callRecord           String?
  statusOrder          String
  masterId             Int?
  result               Decimal?            @db.Decimal(10, 2)
  expenditure          Decimal?            @db.Decimal(10, 2)
  clean                Decimal?            @db.Decimal(10, 2)
  masterChange         Decimal?            @db.Decimal(10, 2)
  bsoDoc               String[]            @default([])
  expenditureDoc       String[]            @default([])
  operatorNameId       Int
  createDate           DateTime            @default(now())
  closingData          DateTime?
  avitoChatId          String?
  callId               String?
  prepayment           Decimal?            @db.Decimal(10, 2)
  dateClosmod          DateTime?
  comment              String?
  cashSubmissionStatus String?
  cashSubmissionDate   DateTime?
  cashSubmissionAmount Decimal?            @db.Decimal(10, 2)
  cashReceiptDoc       String?
  cashApprovedBy       Int?
  cashApprovedDate     DateTime?
  directorId           Int?
  callcentreAdminId    Int?
  callcentreOperatorId Int?

  master             Master?             @relation(fields: [masterId], references: [id], onDelete: SetNull)
  director           Director?           @relation(fields: [directorId], references: [id], onDelete: SetNull)
  callcentreAdmin    CallcentreAdmin?    @relation("CallcentreAdminOrders", fields: [callcentreAdminId], references: [id], onDelete: SetNull)
  callcentreOperator CallcentreOperator? @relation("CallcentreOperatorOrders", fields: [callcentreOperatorId], references: [id], onDelete: SetNull)
  avito              Avito?              @relation(fields: [avitoChatId], references: [chatId], onDelete: SetNull)
  call               Call?               @relation(fields: [callId], references: [callId], onDelete: SetNull)
  cash               Cash?

  @@schema("public")
  @@map("order")
}

model Avito {
  id        Int      @id @default(autoincrement())
  chatId    String   @unique
  city      String?
  name      String?
  phone     String?
  createdAt DateTime @default(now())

  orders Order[]

  @@schema("public")
  @@map("avito")
}

model Call {
  id          Int      @id @default(autoincrement())
  callId      String   @unique @map("call_id")
  phoneClient String   @map("phone_client")
  dateCreate  DateTime @map("date_create")
  duration    Int?
  recordUrl   String?  @map("record_url")

  orders Order[]

  @@schema("public")
  @@map("calls")
}

model Cash {
  id           Int       @id @default(autoincrement())
  orderId      Int       @unique
  amount       Int
  type         String
  status       String
  approvedBy   Int?
  approvedDate DateTime?
  createdAt    DateTime  @default(now())

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  approver Director? @relation("CashApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@schema("public")
  @@map("cash")
}

model ErrorLog {
  id            Int      @id @default(autoincrement())
  timestamp     DateTime @default(now())
  service       String   @db.VarChar(100)
  errorType     String   @db.VarChar(255)
  errorMessage  String   @db.Text
  stackTrace    String?  @db.Text
  userId        Int?
  userRole      String?  @db.VarChar(50)
  requestUrl    String?  @db.VarChar(500)
  requestMethod String?  @db.VarChar(10)
  ip            String?  @db.VarChar(45)
  userAgent     String?  @db.Text
  metadata      Json?    @db.JsonB

  @@index([timestamp(sort: Desc)])
  @@index([service, timestamp(sort: Desc)])
  @@index([errorType])
  @@index([userId])
  @@schema("error_logs")
  @@map("error_logs")
}
