generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth_service"]
}

// ─────────────────────────────────────────
// Schema: auth_service
// ─────────────────────────────────────────

/// Администраторы системы
model Admin {
  id        Int       @id @default(autoincrement())
  role      String    @db.VarChar(50)              /// Роль пользователя
  name      String    @db.VarChar(255)             /// ФИО
  login     String    @unique @db.VarChar(255)     /// Логин для входа
  password  String    @db.VarChar(255)             /// Хеш пароля (bcrypt)
  status    String    @db.VarChar(50)              /// Статус (active/inactive)
  note      String?   @db.Text                    /// Заметка
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")           /// Soft delete

  @@index([status])
  @@schema("auth_service")
  @@map("admins")
}

/// Операторы колл-центра
model Operator {
  id         Int       @id @default(autoincrement())
  role       String    @db.VarChar(50)             /// Роль пользователя
  name       String    @db.VarChar(255)            /// ФИО
  login      String    @unique @db.VarChar(255)    /// Логин для входа
  password   String    @db.VarChar(255)            /// Хеш пароля (bcrypt)
  status     String    @db.VarChar(50)             /// Статус (active/inactive)
  cityIds    Int[]     @default([]) @map("city_ids") /// ID городов из references_service
  passport   String?   @db.VarChar(500)            /// Ссылка на скан паспорта
  contract   String?   @db.VarChar(500)            /// Ссылка на скан договора
  note       String?   @db.Text                   /// Заметка
  sipAddress String?   @map("sip_address") @db.VarChar(255) /// SIP адрес для телефонии
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")           /// Soft delete

  workSessions OperatorWorkSession[]

  @@index([status])
  @@index([name])
  @@schema("auth_service")
  @@map("operators")
}

/// Директора (руководители по городам)
model Director {
  id        Int       @id @default(autoincrement())
  role      String    @db.VarChar(50)              /// Роль пользователя
  name      String    @db.VarChar(255)             /// ФИО
  login     String    @unique @db.VarChar(255)     /// Логин для входа
  password  String    @db.VarChar(255)             /// Хеш пароля (bcrypt)
  status    String    @db.VarChar(50)              /// Статус (active/inactive)
  cityIds   Int[]     @default([]) @map("city_ids") /// ID городов из references_service
  passport  String?   @db.VarChar(500)             /// Ссылка на скан паспорта
  contract  String?   @db.VarChar(500)             /// Ссылка на скан договора
  note      String?   @db.Text                    /// Заметка
  tgId      String?   @map("tg_id") @db.VarChar(50) /// Telegram ID для уведомлений
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")           /// Soft delete

  @@index([status])
  @@index([name])
  @@schema("auth_service")
  @@map("directors")
}

/// Мастера (исполнители заказов)
model Master {
  id        Int       @id @default(autoincrement())
  role      String    @db.VarChar(50)              /// Роль пользователя
  name      String    @db.VarChar(255)             /// ФИО
  login     String?   @unique @db.VarChar(255)     /// Логин (опционально)
  password  String?   @db.VarChar(255)             /// Хеш пароля (опционально)
  status    String    @db.VarChar(50)              /// Статус (active/inactive)
  cityIds   Int[]     @default([]) @map("city_ids") /// ID городов из references_service
  passport  String?   @db.VarChar(500)             /// Ссылка на скан паспорта
  contract  String?   @db.VarChar(500)             /// Ссылка на скан договора
  note      String?   @db.Text                    /// Заметка
  chatId    String?   @map("chat_id") @db.VarChar(50) /// Telegram Chat ID
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")           /// Soft delete

  schedules MasterSchedule[]

  @@index([status])
  @@index([name])
  @@index([chatId])
  @@schema("auth_service")
  @@map("masters")
}

/// Расписание мастеров
model MasterSchedule {
  id        Int      @id @default(autoincrement())
  masterId  Int      @map("master_id")             /// FK на masters
  date      DateTime @db.Date                      /// Дата
  status    String   @db.VarChar(50)               /// working/day_off/vacation
  note      String?  @db.Text                     /// Заметка
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  master Master @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@unique([masterId, date])
  @@index([masterId])
  @@index([date])
  @@index([status])
  @@index([date, status])
  @@schema("auth_service")
  @@map("master_schedules")
}

/// Рабочие сессии операторов
model OperatorWorkSession {
  id         Int       @id @default(autoincrement())
  operatorId Int       @map("operator_id")         /// FK на operators
  startedAt  DateTime  @map("started_at")          /// Начало смены
  endedAt    DateTime? @map("ended_at")            /// Конец смены
  status     String    @db.VarChar(50)             /// active/break/ended
  createdAt  DateTime  @default(now()) @map("created_at")

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@index([status])
  @@index([startedAt])
  @@index([operatorId, startedAt])
  @@schema("auth_service")
  @@map("operator_work_sessions")
}

/// Сессии пользователей (JWT refresh tokens)
model Session {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")            /// ID пользователя
  userType     String   @map("user_type") @db.VarChar(20) /// admin/operator/director/master
  refreshToken String   @map("refresh_token") @db.VarChar(500) /// Refresh token
  ip           String?  @db.VarChar(45)            /// IP адрес
  userAgent    String?  @map("user_agent") @db.Text /// User Agent
  expiresAt    DateTime @map("expires_at")         /// Срок действия
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, userType])
  @@index([refreshToken])
  @@index([expiresAt])
  @@schema("auth_service")
  @@map("sessions")
}
