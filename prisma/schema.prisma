  expiresAt    DateTime @map("expires_at")         /// Срок действия
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, userType])
  @@index([refreshToken])
  @@index([expiresAt])
  @@schema("auth_service")
  @@map("sessions")
}
